@echo off
cd /d D:\repos\ferco-posta
node -e "const fs = require('fs'); const path = require('path'); const configDir = path.join(__dirname, 'frontend', 'src', 'features', 'configuracion'); fs.mkdirSync(configDir, { recursive: true }); const sourceJsx = path.join(__dirname, 'frontend', 'src', 'features', 'dashboard', 'Configuracion.jsx'); const sourceCss = path.join(__dirname, 'frontend', 'src', 'features', 'dashboard', 'Configuracion.css'); const destJsx = path.join(configDir, 'Configuracion.jsx'); const destCss = path.join(configDir, 'Configuracion.css'); if (fs.existsSync(sourceJsx)) { const jsxContent = fs.readFileSync(sourceJsx, 'utf8'); fs.writeFileSync(destJsx, jsxContent); } if (fs.existsSync(sourceCss)) { const cssContent = fs.readFileSync(sourceCss, 'utf8'); fs.writeFileSync(destCss, cssContent); } const files = fs.readdirSync(configDir); console.log('Created configuracion directory with files:'); files.forEach(f => console.log(' - ' + f));"
