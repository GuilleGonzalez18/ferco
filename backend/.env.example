# =========================
# Backend - entorno local/producción
# Copiar a .env y completar valores reales
# =========================

# Puerto HTTP del backend
PORT=3001

# --- Base de datos PostgreSQL (preferido: variables PG*) ---
# Host de PostgreSQL (Supabase pooler o local)
PGHOST=localhost
# Puerto de PostgreSQL
PGPORT=5432
# Nombre de base de datos
PGDATABASE=ferco_db
# Usuario de PostgreSQL
PGUSER=postgres
# Password de PostgreSQL
PGPASSWORD=change_me

# --- Alias legacy de DB (compatibilidad con scripts viejos) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ferco_db
DB_USER=postgres
DB_PASSWORD=change_me

# --- Auth JWT ---
# Clave secreta para firmar tokens (usar valor largo y aleatorio)
JWT_SECRET=change_me_super_long_secret
# Duración del token JWT (ej: 7d, 24h)
JWT_EXPIRES_IN=7d

# --- CORS ---
# Origen(es) permitidos para frontend, separados por coma
# Ej: https://tu-front.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- SMTP (Brevo/Gmail/etc) para envío de correos ---
# Host SMTP (Brevo: smtp-relay.brevo.com)
SMTP_HOST=
# Puerto SMTP (587 TLS o 465 SSL)
SMTP_PORT=587
# Usuario/login SMTP
SMTP_USER=
# Password/API key SMTP
SMTP_PASS=
# true si usas SSL directo (normalmente 465), false para STARTTLS (587)
SMTP_SECURE=false
# Remitente visible de correo
# Ej: Ferco <no-reply@tu-dominio.com>
SMTP_FROM=
# API Key de Brevo para envío HTTP (recomendado en Render)
# Si se define, se usa primero y evita problemas de puertos SMTP bloqueados.
BREVO_API_KEY=

# --- Recuperación de contraseña por código ---
# Minutos de validez del código enviado por correo
RESET_CODE_TTL_MINUTES=10

# --- Scripts de dump/import ---
# Ruta del archivo dump SQL (db:export/db:import)
DUMP_FILE=db-export.sql
# Ruta binaria de pg_dump (opcional si ya está en PATH)
PG_DUMP_BIN=pg_dump
# Ruta binaria de psql (opcional si ya está en PATH)
PSQL_BIN=psql

# --- Seed de datos de prueba ---
# Cantidad de productos a crear
SEED_PRODUCTOS=45
# Cantidad de clientes a crear
SEED_CLIENTES=80
# Cantidad de ventas a crear
SEED_VENTAS=320
