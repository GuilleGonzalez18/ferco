{
  "name": "mercatus-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "node --test src/__tests__/validate.test.js src/__tests__/auth.test.js src/__tests__/cfeHelpers.test.js src/__tests__/pbt.test.js",
    "db:setup": "npm run db:schema && npm run db:migrate",
    "db:schema": "node src/scripts/bootstrapSchema.js",
    "db:migrate": "node src/scripts/runMigration.js",
    "db:export": "node src/scripts/exportDump.js",
    "db:import": "node src/scripts/importDump.js",
    "db:seed:test": "node src/scripts/seedClientesVentasTest.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "fast-check": "^4.7.0"
  }
}
